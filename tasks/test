# List available commands
[private]
default:
  just --justfile {{justfile()}} --list test

# Check if Kubernetes cluster is available and configured
[private]
_check-cluster:
  #!/usr/bin/env bash
  set +e

  KUBECTL_TIMEOUT="${KUBECTL_TIMEOUT:-5s}"

  # Check if kubectl is available
  if ! command -v kubectl &> /dev/null; then
      exit 1
  fi

  # Check if we can connect to the cluster (fail fast when API is unreachable)
  if ! kubectl --request-timeout="$KUBECTL_TIMEOUT" cluster-info &> /dev/null; then
      exit 1
  fi

  # Check if we can get nodes (basic connectivity test)
  if ! kubectl --request-timeout="$KUBECTL_TIMEOUT" get nodes &> /dev/null; then
      exit 1
  fi

  exit 0

# Check test k8s cluster available
cluster-available:
  #!/usr/bin/env bash
  set -e

  KUBECTL_TIMEOUT="${KUBECTL_TIMEOUT:-5s}"

  echo "Checking for Kubernetes cluster..."
  # Use the test module's private _check-cluster recipe explicitly
  if ! KUBECTL_TIMEOUT="$KUBECTL_TIMEOUT" just test _check-cluster; then
      echo "⚠️  Kubernetes cluster not available"
      echo "📦 Initializing test cluster (this may take a few minutes)..."
      # Non-interactive mode will be auto-detected (no TTY in CI)
      just test cluster-init
  else
      echo "✓ Kubernetes cluster is available"
      echo "📦 Reconciling cluster prerequisites..."
      just test cluster-init
  fi
  echo ""

# Setup Talos Kubernetes cluster for testing (idempotent)
cluster-init:
  #!/usr/bin/env bash
  set -e
  
  CLUSTER_NAME="${TALOS_CLUSTER_NAME:-scaleodm-test}"
  WORKER_MEMORY="${TALOS_WORKER_MEMORY:-5.0GiB}"
  CONTROL_PLANE_MEMORY="${TALOS_CONTROL_PLANE_MEMORY:-2.0GiB}"
  NAMESPACE="${K8S_NAMESPACE:-argo}"
  ARGO_VERSION="${ARGO_WORKFLOWS_VERSION:-v3.7.3}"
  WORKFLOW_S3_SECRET_NAME="${AWS_S3_SECRET_NAME:-scaleodm-secrets}"
  WORKFLOW_S3_ACCESS_KEY="${AWS_ACCESS_KEY_ID:-admin}"
  WORKFLOW_S3_SECRET_KEY="${AWS_SECRET_ACCESS_KEY:-somelongpassword}"
  WORKFLOW_S3_REGION="${AWS_DEFAULT_REGION:-us-east-1}"
  ARGO_ARCHIVE_LOG_BUCKET="${SCALEODM_ARGO_ARCHIVE_LOG_BUCKET:-argo-logs}"
  ARGO_ARCHIVE_S3_ENDPOINT="${SCALEODM_ARGO_ARCHIVE_S3_ENDPOINT:-${SCALEODM_WORKFLOW_S3_ENDPOINT:-}}"
  ARGO_ARCHIVE_S3_INSECURE="${SCALEODM_ARGO_ARCHIVE_S3_INSECURE:-true}"

  label_workflow_nodes() {
      # Workflows pin themselves to Karpenter-style labels (node-type=cpu,
      # karpenter.sh/capacity-type=spot). The Docker-mode Talos worker has
      # neither, so without this the workflow pod sits Pending forever with
      # "node(s) didn't match Pod's node affinity/selector".
      local workers
      workers=$(kubectl get nodes -l '!node-role.kubernetes.io/control-plane' -o name 2>/dev/null || true)
      if [ -z "$workers" ]; then
          echo "⚠️  No worker nodes found to label; skipping workflow node labels"
          return 0
      fi
      echo "📦 Labeling worker nodes for workflow scheduling..."
      while IFS= read -r node; do
          [ -z "$node" ] && continue
          kubectl label "$node" \
              node-type=cpu \
              karpenter.sh/capacity-type=spot \
              --overwrite >/dev/null
      done <<< "$workers"
      echo "✓ Worker nodes labeled (node-type=cpu, karpenter.sh/capacity-type=spot)"
  }

  configure_argo_archive_logs() {
      local endpoint="$ARGO_ARCHIVE_S3_ENDPOINT"
      if [ -z "$endpoint" ]; then
          local talos_gateway_ip
          talos_gateway_ip=$(docker network inspect "$CLUSTER_NAME" 2>/dev/null | python3 -c 'import json,sys; data=json.load(sys.stdin); print((data[0].get("IPAM",{}).get("Config",[{}])[0].get("Gateway", "")) if data else "", end="")' 2>/dev/null || true)
          if [ -n "$talos_gateway_ip" ]; then
              endpoint="http://${talos_gateway_ip}:31102"
          else
              endpoint="http://host.docker.internal:31102"
          fi
      fi

      local endpoint_hostport="${endpoint#http://}"
      endpoint_hostport="${endpoint_hostport#https://}"

      echo "📦 Configuring Argo archived logs..."
      kubectl apply -n "$NAMESPACE" -f - <<EOF
  apiVersion: v1
  kind: ConfigMap
  metadata:
    name: workflow-controller-configmap
  data:
    config: |
      artifactRepository:
        archiveLogs: true
        s3:
          bucket: ${ARGO_ARCHIVE_LOG_BUCKET}
          endpoint: ${endpoint_hostport}
          insecure: ${ARGO_ARCHIVE_S3_INSECURE}
          keyFormat: "{{ "{{" }}workflow.namespace{{ "}}" }}/{{ "{{" }}workflow.name{{ "}}" }}/{{ "{{" }}pod.name{{ "}}" }}"
          accessKeySecret:
            name: ${WORKFLOW_S3_SECRET_NAME}
            key: AWS_ACCESS_KEY_ID
          secretKeySecret:
            name: ${WORKFLOW_S3_SECRET_NAME}
            key: AWS_SECRET_ACCESS_KEY
      workflowDefaults:
        spec:
          archiveLogs: true
  EOF
      kubectl rollout restart deployment/workflow-controller -n "$NAMESPACE" >/dev/null 2>&1 || true
      echo "✓ Argo archived logs configured for s3://${ARGO_ARCHIVE_LOG_BUCKET}"
  }
  
  echo "🚀 Setting up Talos cluster for ScaleODM testing..."
  echo "   Cluster name: $CLUSTER_NAME"
  echo "   Worker memory: ${WORKER_MEMORY}"
  echo "   Control plane memory: ${CONTROL_PLANE_MEMORY}"
  echo ""
  
  # Ensure br_netfilter kernel module is loaded (required for Flannel networking in Docker)
  if ! lsmod | grep -q "^br_netfilter"; then
      echo "📦 Loading br_netfilter kernel module..."
      if sudo modprobe br_netfilter 2>/dev/null; then
          echo "✓ br_netfilter module loaded"
      else
          echo "⚠️  Warning: Failed to load br_netfilter module"
          echo "   This may cause issues with Kubernetes networking in Docker"
          echo "   If cluster creation fails, ensure the module can be loaded"
      fi
  else
      echo "✓ br_netfilter module already loaded"
  fi
  
  # Install required tools if missing
  just _install-curl
  just _install-talosctl
  just _install-kubectl
  
  # Check if the expected cluster exists and is accessible
  # Scope `talosctl cluster show` to the expected cluster name so we
  # can correctly detect when that cluster already exists.
  CLUSTER_SHOW_OUTPUT=$(talosctl cluster show --name "$CLUSTER_NAME" 2>/dev/null || echo "")
  if [ -n "$CLUSTER_SHOW_OUTPUT" ]; then
      CURRENT_CLUSTER=$(echo "$CLUSTER_SHOW_OUTPUT" | grep "^NAME" | awk '{print $2}' | head -1 | tr -d '\n\r' || echo "")
      NODE_COUNT=$(echo "$CLUSTER_SHOW_OUTPUT" | grep -E "^[a-z].*-.*(controlplane|worker)" | wc -l | tr -d '[:space:]')
      
      if [ -z "$NODE_COUNT" ] || ! [ "$NODE_COUNT" -ge 0 ] 2>/dev/null; then
          NODE_COUNT=0
      fi
      
      # Check if a different cluster is running
      if [ -n "$CURRENT_CLUSTER" ] && [ "$NODE_COUNT" -gt 0 ] && [ "$CURRENT_CLUSTER" != "$CLUSTER_NAME" ]; then
          echo "❌ Error: A different cluster '$CURRENT_CLUSTER' is currently running"
          echo "   Expected cluster: $CLUSTER_NAME"
          echo "   Please destroy the existing cluster or set TALOS_CLUSTER_NAME=$CURRENT_CLUSTER"
          exit 1
      fi
      
      # Check if expected cluster exists but is not accessible
      if [ -n "$CURRENT_CLUSTER" ] && [ "$CURRENT_CLUSTER" = "$CLUSTER_NAME" ] && [ "$NODE_COUNT" -gt 0 ]; then
          if ! kubectl cluster-info &> /dev/null || ! kubectl get nodes &> /dev/null; then
              echo "❌ Error: Cluster '$CLUSTER_NAME' exists but is not accessible via kubectl"
              echo "   Please check your cluster status and fix any issues"
              exit 1
          fi
          
          # Cluster exists and is accessible - verify configuration
          echo "✓ Cluster '$CLUSTER_NAME' found and accessible"
          
          # Verify namespace exists
          if ! kubectl get namespace "$NAMESPACE" &> /dev/null; then
              echo "⚠️  Namespace '$NAMESPACE' missing, will create"
          else
              echo "✓ Namespace '$NAMESPACE' exists"
          fi
          
          # Verify Argo Workflows is installed
          if ! kubectl get crd workflows.argoproj.io &> /dev/null; then
              echo "⚠️  Argo Workflows not installed, will install"
          else
              echo "✓ Argo Workflows CRD exists"
              
              # If everything is configured, we are done
              if kubectl get namespace "$NAMESPACE" &> /dev/null; then
                  echo ""
                  echo "✅ Cluster is already configured and ready!"
                  echo ""
                  
                  # Ensure service account and RBAC exist (idempotent)
                  echo "📦 Verifying service account and RBAC..."
                  kubectl create serviceaccount argo-odm -n "$NAMESPACE" --dry-run=client -o yaml | kubectl apply -f - &> /dev/null
                  kubectl create clusterrolebinding argo-odm-admin \
                      --clusterrole=admin \
                      --serviceaccount="$NAMESPACE:argo-odm" \
                      --dry-run=client -o yaml | kubectl apply -f - &> /dev/null
                  echo "✓ Service account and RBAC verified"

                  # Ensure workflow S3 credentials secret exists (idempotent)
                  echo "📦 Verifying workflow S3 credentials secret..."
                  kubectl create secret generic "$WORKFLOW_S3_SECRET_NAME" -n "$NAMESPACE" \
                      --from-literal=AWS_ACCESS_KEY_ID="$WORKFLOW_S3_ACCESS_KEY" \
                      --from-literal=AWS_SECRET_ACCESS_KEY="$WORKFLOW_S3_SECRET_KEY" \
                      --from-literal=AWS_DEFAULT_REGION="$WORKFLOW_S3_REGION" \
                      --dry-run=client -o yaml | kubectl apply -f - &> /dev/null
                  echo "✓ Workflow S3 credentials secret verified"
                  label_workflow_nodes
                  configure_argo_archive_logs
                  echo ""
                  exit 0
              fi
          fi
      fi
  fi
  
  echo "📦 Creating Talos cluster $CLUSTER_NAME..."

  # Lower kubelet eviction thresholds to prevent false disk-pressure taints
  # in the Docker provider (containers inherit host disk but may report limited space)
  # Use a strategic merge patch because JSON6902 patches are not supported
  # for Talos multi-document machine configuration.
  KUBELET_PATCH=$'machine:\n  kubelet:\n    extraConfig:\n      evictionHard:\n        nodefs.available: "5%"\n        imagefs.available: "5%"'

  talosctl cluster create docker \
    --name "$CLUSTER_NAME" \
    --workers 1 \
    --memory-controlplanes "${CONTROL_PLANE_MEMORY}" \
    --memory-workers "${WORKER_MEMORY}" \
    --cpus-controlplanes "1.0" \
    --cpus-workers "2.0" \
    --config-patch "$KUBELET_PATCH"

  # Ensure kubeconfig is merged (talosctl may fail to set context if stale configs exist)
  echo "📦 Merging kubeconfig from cluster..."
  CP_IP="10.5.0.2"
  talosctl kubeconfig --nodes "$CP_IP" --force

  # Wait for nodes and CoreDNS separately with generous timeouts
  echo "⏳ Waiting for nodes to be ready..."
  kubectl wait --for=condition=Ready nodes --all --timeout=5m || {
      echo "⚠️  Warning: Some nodes may not be ready yet"
  }

  echo "⏳ Waiting for CoreDNS to be ready..."
  kubectl wait --for=condition=Ready pod -l k8s-app=kube-dns -n kube-system --timeout=10m || {
      echo "⚠️  Warning: CoreDNS may not be ready yet"
  }

  echo ""
  echo "✓ Talos cluster created successfully!"
  echo ""
  
  # Get kubeconfig context name
  CONTEXT=$(kubectl config current-context)
  echo "✓ Cluster is ready!"
  echo "   Kubeconfig context: $CONTEXT"
  echo ""
  
  # Install Argo Workflows if not already installed
  if ! kubectl get namespace "$NAMESPACE" &> /dev/null; then
      echo "📦 Creating namespace: $NAMESPACE"
      kubectl create namespace "$NAMESPACE"
  fi
  
  if ! kubectl get crd workflows.argoproj.io &> /dev/null; then
      echo "📦 Installing Argo Workflows $ARGO_VERSION..."
      kubectl apply -n "$NAMESPACE" -f "https://github.com/argoproj/argo-workflows/releases/download/${ARGO_VERSION}/install.yaml"
      
      # Wait for Argo Workflows to be ready
      echo "⏳ Waiting for Argo Workflows to be ready..."
      kubectl wait --for=condition=ready pod -l app=workflow-controller -n "$NAMESPACE" --timeout=5m || true
      kubectl wait --for=condition=ready pod -l app=argo-server -n "$NAMESPACE" --timeout=5m || true
  else
      echo "✓ Argo Workflows already installed"
  fi
  
  # Create service account for workflows
  echo "📦 Setting up service account for workflows..."
  kubectl create serviceaccount argo-odm -n "$NAMESPACE" --dry-run=client -o yaml | kubectl apply -f -
  
  # Bind admin role to service account for workflow execution
  echo "📦 Setting up RBAC for workflows..."
  kubectl create clusterrolebinding argo-odm-admin \
      --clusterrole=admin \
      --serviceaccount="$NAMESPACE:argo-odm" \
      --dry-run=client -o yaml | kubectl apply -f -

  # Create workflow S3 credentials secret for workflow pod env refs
  echo "📦 Setting up workflow S3 credentials secret..."
  kubectl create secret generic "$WORKFLOW_S3_SECRET_NAME" -n "$NAMESPACE" \
      --from-literal=AWS_ACCESS_KEY_ID="$WORKFLOW_S3_ACCESS_KEY" \
      --from-literal=AWS_SECRET_ACCESS_KEY="$WORKFLOW_S3_SECRET_KEY" \
      --from-literal=AWS_DEFAULT_REGION="$WORKFLOW_S3_REGION" \
      --dry-run=client -o yaml | kubectl apply -f -
  label_workflow_nodes
  configure_argo_archive_logs

  echo ""
  echo "✅ Talos cluster setup complete!"
  echo ""
  echo "Next steps:"
  echo "  1. Start compose services: just start"
  echo "  2. Check cluster status: kubectl get nodes"
  echo "  3. Check Argo Workflows: kubectl get pods -n $NAMESPACE"
  echo ""
  echo "To destroy the cluster later:"
  echo "  just test cluster-destroy"

# Destroy the Talos test cluster
cluster-destroy:
  #!/usr/bin/env bash
  set -e

  CLUSTER_NAME="${TALOS_CLUSTER_NAME:-scaleodm-test}"

  echo "Destroying Talos cluster: $CLUSTER_NAME"
  talosctl cluster destroy --name "$CLUSTER_NAME" || true

  # Clean up any leftover Docker containers and networks
  echo "Cleaning up leftover Docker resources..."
  LEFTOVER_CONTAINERS=$(docker ps -a --filter "name=${CLUSTER_NAME}" -q 2>/dev/null || true)
  if [ -n "$LEFTOVER_CONTAINERS" ]; then
      docker rm -f $LEFTOVER_CONTAINERS
      echo "  Removed leftover containers"
  fi
  if docker network rm "$CLUSTER_NAME" 2>/dev/null; then
      echo "  Removed leftover network"
  fi

  # Remove stale Talos state directory
  TALOS_STATE_DIR="${HOME}/.talos/clusters/${CLUSTER_NAME}"
  if [ -d "$TALOS_STATE_DIR" ]; then
      rm -rf "$TALOS_STATE_DIR"
      echo "  Removed state directory: $TALOS_STATE_DIR"
  fi

  # Remove stale talosconfig and kubeconfig contexts
  talosctl config remove "$CLUSTER_NAME" 2>/dev/null || true
  kubectl config delete-context "admin@$CLUSTER_NAME" 2>/dev/null || true
  kubectl config delete-cluster "$CLUSTER_NAME" 2>/dev/null || true
  kubectl config delete-user "admin@$CLUSTER_NAME" 2>/dev/null || true
  # Clean up any renamed contexts (e.g. scaleodm-test-2, scaleodm-test-3)
  for ctx in $(talosctl config contexts 2>/dev/null | grep "^${CLUSTER_NAME}-[0-9]" || true); do
      talosctl config remove "$ctx" 2>/dev/null || true
  done

  echo "Cluster destroyed"

# Build the local API image used by compose test runs
build-api-image:
  #!/usr/bin/env bash
  set -e

  cd {{justfile_directory()}}

  echo "Building local API image (ghcr.io/hotosm/scaleodm:${TAG_OVERRIDE:-ci})..."
  docker compose build api

# Validate Helm chart ingress guardrails (no cluster required)
chart-ingress-guardrails:
  #!/usr/bin/env bash
  set -euo pipefail

  cd {{justfile_directory()}}

  if ! command -v helm &> /dev/null; then
      echo "❌ Error: helm is required for chart ingress guardrail checks"
      exit 1
  fi

  echo "Running chart ingress guardrail checks..."

  just chart dependencies

  RENDERED_FILE=$(mktemp)
  ERROR_FILE=$(mktemp)
  trap 'rm -f "$RENDERED_FILE" "$ERROR_FILE"' EXIT

  # 1) Ingress renders with only /ui path when ingress and UI are enabled
  helm template scaleodm ./chart \
      --set ingress.enabled=true \
      --set config.ui.enabled=true > "$RENDERED_FILE"

  INGRESS_PATHS=$(awk '
    /^kind: Ingress$/ { in_ingress=1 }
    in_ingress && /^---$/ { in_ingress=0 }
    in_ingress && /path: / {
      line=$0
      sub(/^.*path: /, "", line)
      print line
    }
  ' "$RENDERED_FILE")

  if [ -z "$INGRESS_PATHS" ]; then
      echo "❌ Expected ingress paths, but none were rendered"
      exit 1
  fi

  while IFS= read -r path; do
      if [ "$path" != "/ui" ]; then
          echo "❌ Expected only /ui ingress path, found: $path"
          exit 1
      fi
  done <<< "$INGRESS_PATHS"

  # 2) Enabling ingress while UI is disabled must fail rendering
  if helm template scaleodm ./chart \
      --set ingress.enabled=true \
      --set config.ui.enabled=false > /dev/null 2> "$ERROR_FILE"; then
      echo "❌ Expected helm template to fail when ingress.enabled=true and config.ui.enabled=false"
      exit 1
  fi

  if ! grep -q "ingress is UI-only and requires config.ui.enabled=true" "$ERROR_FILE"; then
      echo "❌ Expected UI-only ingress guardrail error message was not found"
      exit 1
  fi

  # 3) User-provided path overrides must not expose non-UI paths
  helm template scaleodm ./chart \
      --set ingress.enabled=true \
      --set config.ui.enabled=true \
      --set ingress.hosts[0].paths[0].path=/openapi.json \
      --set ingress.hosts[0].paths[0].pathType=Prefix > "$RENDERED_FILE"

  INGRESS_PATHS=$(awk '
    /^kind: Ingress$/ { in_ingress=1 }
    in_ingress && /^---$/ { in_ingress=0 }
    in_ingress && /path: / {
      line=$0
      sub(/^.*path: /, "", line)
      print line
    }
  ' "$RENDERED_FILE")

  while IFS= read -r path; do
      if [ "$path" != "/ui" ]; then
          echo "❌ Path override escaped UI-only guardrail: $path"
          exit 1
      fi
  done <<< "$INGRESS_PATHS"

  echo "✓ Chart ingress guardrail checks passed"

# Run all tests (requires Talos cluster and compose services)
all:
  #!/usr/bin/env bash
  set -e

  # Will start DB and S3 if not already running
  # Automatically initializes cluster if not available

  cd {{justfile_directory()}}

  just test chart-ingress-guardrails
  just test cluster-available
  just test build-api-image

  echo "Running tests..."
  COMPOSE_TEST_ARGS="-f compose.yaml -f compose.test.yaml"
  cleanup() {
    docker compose $COMPOSE_TEST_ARGS down --remove-orphans || true
  }
  trap cleanup EXIT

  docker compose $COMPOSE_TEST_ARGS up --detach --wait db s3 s3-init || {
    echo "❌ Failed to start test dependencies."
    docker compose $COMPOSE_TEST_ARGS ps || true
    docker compose $COMPOSE_TEST_ARGS logs --no-color --tail=120 api db s3 s3-init || true
    exit 1
  }

  docker compose $COMPOSE_TEST_ARGS run --rm api || {
    echo "❌ Test run failed."
    docker compose $COMPOSE_TEST_ARGS ps || true
    docker compose $COMPOSE_TEST_ARGS logs --no-color --tail=120 api db s3 s3-init || true
    exit 1
  }

# Run unit tests only (no external dependencies)
unit:
  go test -v -short ./app/api/helpers_test.go ./app/api/helpers.go ./app/workflows/workflow_test.go

# Run integration tests only (requires DB)
integration:
  #!/usr/bin/env bash
  set -e

  cd {{justfile_directory()}}
  just test build-api-image

  echo "Running integration tests..."
  docker compose -f compose.yaml -f compose.test.yaml run --rm api go test -v -short ./app/meta/... ./app/db/... ./app/api/...

# Run E2E tests only (requires DB, S3, and K8s)
e2e:
  #!/usr/bin/env bash
  set -e

  cd {{justfile_directory()}}

  just test cluster-available
  just test build-api-image
  echo "Running E2E tests..."
  docker compose -f compose.yaml -f compose.test.yaml run --rm api go test -v -tags=e2e .
