# Test environment configuration for local services.
# This file is used by compose.test.yaml to force Garage S3 usage in tests.

SCALEODM_DATABASE_URL=postgres://odm:odm@localhost:31101/scaleodm?sslmode=disable
SCALEODM_CLUSTER_URL=http://localhost:31100
SCALEODM_ODM_IMAGE=docker.io/opendronemap/odm:3.5.6

# Garage S3 configuration (for local testing)
SCALEODM_S3_ENDPOINT=http://localhost:31102
SCALEODM_S3_ACCESS_KEY=odm
SCALEODM_S3_SECRET_KEY=somelongpassword
