# Test environment configuration for local services.
# This file is used by compose.test.yaml to force RustFS S3 usage in tests.

SCALEODM_DATABASE_URL=postgres://odm:odm@localhost:31101/scaleodm?sslmode=disable
SCALEODM_ODM_IMAGE=ghcr.io/hotosm/odm:3.6.0

# RustFS S3 configuration (for local testing)
AWS_S3_ENDPOINT=http://localhost:31102
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=somelongpassword
